---
interface Props {
  active?:
    | "art"
    | "links"
    | "stream"
    | "events"
    | "commission-monthlys"
    | "commission-ychs"
    | "commission-customs"
    | "home";
}
const { active = "home" } = Astro.props;

const items = [
  { id: "art", label: "ART", href: "/art", icon: "▨" },
  { id: "links", label: "LINKS", href: "/links", icon: "⌘" },
  { id: "stream", label: "STREAM", href: "/stream", icon: "◉" },
  { id: "events", label: "EVENTS", href: "/events", icon: "◈" },
] as const;

const commissions = [
  { id: "commission-monthlys", label: "MONTHLYS", href: "/commission/monthlys" },
  { id: "commission-ychs", label: "YCHS", href: "/commission/ychs" },
  { id: "commission-customs", label: "CUSTOMS", href: "/commission/customs" },
] as const;
---

<nav class="nav" aria-label="Primary">
  {
    items.map((item) => (
      <a
        href={item.href}
        class:list={["row caps", { "nav-active": active === item.id }]}
        aria-current={active === item.id ? "page" : undefined}
      >
        <span class="dash">–</span>
        <span class="label">{item.label}</span>
        <span class="icon mono" aria-hidden="true">
          {item.icon}
        </span>
      </a>
    ))
  }

  <div class="group">
    <span class="group-head caps mono">Commissions</span>
    <span class="icon mono" aria-hidden="true">✎</span>
  </div>
  {
    commissions.map((item) => (
      <a
        href={item.href}
        class:list={["row sub caps", { "nav-active": active === item.id }]}
        aria-current={active === item.id ? "page" : undefined}
      >
        <span class="dash">–</span>
        <span class="label">{item.label}</span>
      </a>
    ))
  }
</nav>

<style>
  .nav {
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem var(--gutter);
    border-top: 1px solid var(--line);
    font-size: var(--step-1);
    transition: background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }
  .row:last-child {
    border-bottom: 1px solid var(--line);
  }
  .row:hover:not(.nav-active),
  .row:focus-visible:not(.nav-active) {
    background: var(--surface);
  }
  .group {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem var(--gutter) 0.3rem;
    border-top: 1px solid var(--line);
  }
  .group-head {
    color: var(--ink-dim);
    font-size: var(--step-1);
    letter-spacing: var(--tracking-caps);
  }
  .row.sub {
    grid-template-columns: auto 1fr;
    padding-left: calc(var(--gutter) + 1rem);
    border-top: 0;
    font-size: var(--step-0);
  }
  .dash {
    color: var(--ink-faint);
  }
  .nav-active .dash {
    color: var(--accent-ink);
  }
  .icon {
    opacity: 0.8;
    font-size: 0.9em;
  }
</style>
