---
import "@/styles/global.css";
import Sidebar from "@/components/Sidebar.astro";
import { COOKIE } from "@/data/config";

interface Props {
  title?: string;
  description?: string;
  /** Section id for active nav highlighting. */
  active?:
    | "art"
    | "links"
    | "stream"
    | "events"
    | "commission-monthlys"
    | "commission-ychs"
    | "commission-customs"
    | "home";
  /** Landing page renders without the persistent sidebar shell. */
  bare?: boolean;
  /** Site-relative path for canonical + og:url (e.g. "/events"). */
  path?: string;
  ogType?: "website" | "article";
  ogTitle?: string;
  ogDescription?: string;
  /** Site-relative or absolute image for the share card. */
  ogImage?: string;
}

const {
  title = "LOVE THIS ARTIST",
  description = "Art, streams, socials, and commissions.",
  active = "home",
  bare = false,
  path,
  ogType = "website",
  ogTitle,
  ogDescription,
  ogImage,
} = Astro.props;

// Honor the mode cookie during SSR so the first paint matches the user's choice.
const cookieMode = Astro.cookies.get(COOKIE.mode)?.value;
const initialMode = cookieMode === "nsfw" ? "nsfw" : "sfw";

const canonical = path ? new URL(path, Astro.site).href : undefined;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const shareTitle = ogTitle ?? title;
const shareDescription = ogDescription ?? description;
---

<!doctype html>
<html lang="en" data-mode={initialMode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Open Graph / Twitter — drives link-card embeds on Bluesky, X, Telegram. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="LOVE THIS ARTIST" />
    <meta property="og:title" content={shareTitle} />
    <meta property="og:description" content={shareDescription} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta
      name="twitter:card"
      content={ogImageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={shareTitle} />
    <meta name="twitter:description" content={shareDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {/* Pre-paint: reconcile <html data-mode> with the cookie to avoid a flash. */}
    <script is:inline define:vars={{ key: COOKIE.mode }}>
      try {
        const m = document.cookie.match(new RegExp("(?:^|; )" + key + "=([^;]*)"));
        if (m && decodeURIComponent(m[1]) === "nsfw") {
          document.documentElement.dataset.mode = "nsfw";
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    {
      bare ? (
        <slot />
      ) : (
        <div class="shell">
          <Sidebar active={active} />
          <main class="main" id="main">
            <slot />
          </main>
        </div>
      )
    }
  </body>
</html>

<style>
  .shell {
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr;
    min-height: 100dvh;
  }
  .main {
    min-width: 0;
    padding: var(--gutter);
  }
  @media (max-width: 720px) {
    .shell {
      grid-template-columns: 1fr;
    }
  }
</style>
